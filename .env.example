# 공유 폴더 경로 설정
# Windows + WSL 환경에서 카카오톡에 파일을 전달할 폴더입니다.
# 아래 파일을 .env로 복사한 뒤 본인 경로로 수정하세요.
#
#   cp .env.example .env
#
# WSL 경로 형식으로 입력합니다. (예: /mnt/c/Users/사용자이름/Desktop/kakao-share)
KAKAO_SHARE_DIR=/mnt/c/Users/jhkim/Desktop/kakao-share

# Wine Firefox 브라우저 포함 여부
# true: 이미지 빌드 때 설치 파일을 포함하고 작업표시줄에 Firefox 아이콘을 표시합니다.
# false: 브라우저 설치 파일을 포함하지 않고 Firefox 아이콘도 숨깁니다.
INSTALL_FIREFOX=true
ENABLE_FIREFOX=true
